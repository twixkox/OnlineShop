@using OnlineShopWebApp.Areas.Client.Models
@model ProductViewModel
@{
    ViewData["Title"] = "Добавление товара";
}

<div class="d-flex justify-content-between align-items-center bg-success text-white p-4 mb-4 rounded-3">
    <div>
        <h1 class="h3 mb-0">
            <i class="bi bi-plus-circle me-2"></i>@ViewData["Title"]
        </h1>
        <p class="mb-0 small opacity-75">Заполните форму для создания нового товара</p>
    </div>
    <a asp-action="Index" class="btn btn-light">
        <i class="bi bi-arrow-left me-1"></i>Назад к списку
    </a>
</div>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-white py-3">
                    <h5 class="card-title mb-0">
                        <i class="bi bi-box-seam text-success me-2"></i>
                        Информация о товаре
                    </h5>
                </div>

                <div class="card-body">
                    <form method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="mb-4">
                            <label class="form-label fw-medium" asp-for="Name">
                                <i class="bi bi-tag text-success me-1"></i>Название товара
                            </label>
                            <input class="form-control form-control-lg" asp-for="Name"
                                   placeholder="Например: Яблоня 'Антоновка'" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                            <div class="form-text text-muted">
                                Название должно быть от 2 до 50 символов
                            </div>
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-6">
                                <label class="form-label fw-medium" asp-for="Cost">
                                    <i class="bi bi-currency-ruble text-success me-1"></i>Цена (₽)
                                </label>
                                <input class="form-control" asp-for="Cost" type="number" step="1"
                                       placeholder="0" />
                                <span asp-validation-for="Cost" class="text-danger small"></span>
                                <div class="form-text text-muted">
                                    Укажите цену в рублях
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-medium" asp-for="CategoryId">
                                    <i class="bi bi-grid-3x3-gap-fill text-success me-1"></i>Категория
                                </label>
                                <select class="form-select" asp-for="CategoryId">
                                    <option value="">-- Выберите категорию --</option>
                                    @if (Model.AvailableCategory != null)
                                    {
                                        foreach (var category in Model.AvailableCategory)
                                        {
                                            <option value="@category.Id">@category.Name</option>
                                        }
                                    }
                                </select>
                                <span asp-validation-for="CategoryId" class="text-danger small"></span>
                                <div class="form-text text-muted">
                                    Выберите категорию для товара
                                </div>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-medium" asp-for="Description">
                                <i class="bi bi-text-paragraph text-success me-1"></i>Описание
                            </label>
                            <textarea class="form-control" asp-for="Description"
                                      rows="4" placeholder="Краткое описание товара"></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                            <div class="form-text text-muted">
                                Не более 500 символов
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-medium">
                                <i class="bi bi-image text-success me-1"></i>Изображение товара
                            </label>
                            <input type="file" name="UploadedFile" class="form-control" accept="image/*" id="imageInput" />
                            <div class="form-text text-muted">
                                Поддерживаемые форматы: .jpg, .png, .gif. Не более 2 МБ.
                            </div>
                            <div class="mt-3 text-center" id="imagePreview" style="display: none;">
                                <img src="#" alt="Предпросмотр" class="img-thumbnail" style="max-height: 200px;">
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-5">
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-x-circle me-1"></i>Отмена
                            </a>
                            <button type="submit" class="btn btn-success px-5">
                                <i class="bi bi-check-circle me-2"></i>Добавить товар
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.getElementById('imageInput').addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(event) {
                    const preview = document.getElementById('imagePreview');
                    preview.style.display = 'block';
                    preview.querySelector('img').src = event.target.result;
                };
                reader.readAsDataURL(file);
            } else {
                document.getElementById('imagePreview').style.display = 'none';
            }
        });
    </script>
}