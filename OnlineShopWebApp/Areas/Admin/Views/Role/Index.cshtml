@model List<RoleViewModel>
@{
    ViewData["Title"] = "Управление ролями";
}

<!-- Шапка с заголовком и действиями -->
<div class="d-flex justify-content-between align-items-center bg-success text-white p-4 mb-4 rounded-3">
    <div>
        <h1 class="h3 mb-0">
            <i class="bi bi-shield-lock me-2"></i>@ViewData["Title"]
        </h1>
        <p class="mb-0 small opacity-75">Просмотр и управление ролями пользователей</p>
    </div>
    <a asp-action="Add" class="btn btn-light">
        <i class="bi bi-plus-circle me-1"></i>Создать роль
    </a>
</div>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-12">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <div class="card shadow-sm">
                <div class="card-header bg-white py-3">
                    <h5 class="card-title mb-0">
                        <i class="bi bi-grid-3x3-gap-fill text-success me-2"></i>
                        Список ролей
                    </h5>
                </div>

                <div class="card-body">
                    @if (Model.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Название</th>
                                        <th>Описание</th>
                                        <th class="text-end">Действия</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var role in Model)
                                    {
                                        <tr>
                                            <td class="fw-medium">@role.Name</td>
                                            <td>@role.Description</td>
                                            <td class="text-end">
                                                <div class="btn-group" role="group">
                                                     <form asp-action="Delete" method="post" class="d-inline"
                                                          onsubmit="return confirm('Вы уверены, что хотите удалить эту роль?');">
                                                        <input type="hidden" name="roleId" value="@role.Id" />
                                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                                            <i class="bi bi-trash"></i> Удалить
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted py-5">
                            <i class="bi bi-shield-slash" style="font-size: 3rem;"></i>
                            <p class="mt-3 mb-0">Роли еще не созданы</p>
                            <a asp-action="Add" class="btn btn-success mt-3">
                                <i class="bi bi-plus-circle me-1"></i>Создать первую роль
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>