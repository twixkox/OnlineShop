@using Microsoft.AspNetCore.Identity
@using OnlineShop.Db.Models
@using OnlineShopWebApp.Areas.Admin.Models
@using OnlineShopWebApp.Models
@model RoleViewModel
@{
    ViewData["Title"] = "Добавление роли";
}


<!-- Шапка с заголовком и навигацией -->
<div class="d-flex justify-content-between align-items-center bg-success text-white p-4 mb-4 rounded-3">
    <div>
        <h1 class="h3 mb-0">
            <i class="bi bi-shield-plus me-2"></i>@ViewData["Title"]
        </h1>
        <p class="mb-0 small opacity-75">Создание новой роли пользователей</p>
    </div>
    <a asp-action="Index" class="btn btn-light">
        <i class="bi bi-arrow-left me-1"></i>Назад к списку
    </a>
</div>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-white py-3">
                    <h5 class="card-title mb-0">
                        <i class="bi bi-grid-3x3-gap-fill text-success me-2"></i>
                        Форма создания роли
                    </h5>
                </div>

                <div class="card-body">
                    <form method="post">
                        <div class="text-danger fw-bold" asp-validation-summary="ModelOnly"></div>

                        <!-- Название роли -->
                        <div class="mb-4">
                            <label class="form-label fw-medium" asp-for="Name">
                                <i class="bi bi-tag text-success me-1"></i>Название роли
                            </label>
                            <input class="form-control form-control-lg" asp-for="Name"
                                   placeholder="Введите название роли" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                            <div class="form-text text-muted">
                                Название должно быть уникальным и содержать от 3 до 50 символов
                            </div>
                        </div>

                        <!-- Описание -->
                        <div class="mb-4">
                            <label class="form-label fw-medium" asp-for="Description">
                                <i class="bi bi-text-paragraph text-success me-1"></i>Описание
                            </label>
                            <textarea class="form-control" asp-for="Description"
                                      rows="4" placeholder="Введите описание роли (необязательно)"></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                            <div class="form-text text-muted">
                                Краткое описание назначения роли (не более 200 символов)
                            </div>
                        </div>

                        <!-- Кнопки -->
                        <div class="d-flex justify-content-between align-items-center mt-5">
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-x-circle me-1"></i>Отмена
                            </a>
                            <button type="submit" class="btn btn-success px-5">
                                <i class="bi bi-check-circle me-2"></i>Создать роль
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>