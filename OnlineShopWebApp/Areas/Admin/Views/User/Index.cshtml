@using OnlineShopWebApp.Areas.Client.Models
@model List<UserViewModel>
@{
    ViewData["Title"] = "Пользователи";
}

<div class="d-flex justify-content-between align-items-center bg-success text-white p-4 mb-4 rounded-3">
    <div>
        <h1 class="h3 mb-0">
            <i class="bi bi-people me-2"></i>@ViewData["Title"]
        </h1>
        <p class="mb-0 small opacity-75">Просмотр и управление пользователями системы</p>
    </div>
    <a asp-area="Admin" asp-controller="User" asp-action="Add" class="btn btn-light">
        <i class="bi bi-person-plus me-1"></i>Добавить пользователя
    </a>
</div>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-white py-3">
                    <h5 class="card-title mb-0">
                        <i class="bi bi-grid-3x3-gap-fill text-success me-2"></i>
                        Список пользователей
                    </h5>
                </div>

                <div class="card-body">
                    @if (Model != null && Model.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th scope="col">#</th>
                                        <th scope="col">Email (логин)</th>
                                        <th scope="col">Имя</th>
                                        <th scope="col">Фамилия</th>
                                        <th scope="col">Телефон</th>
                                        <th scope="col">Роль</th>
                                        <th scope="col" class="text-end">Действия</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (var i = 0; i < Model.Count; i++)
                                    {
                                        var user = Model[i];
                                        string roleClass = user.Role?.ToLower() switch
                                        {
                                            "администратор" => "bg-danger",
                                            "модератор" => "bg-warning text-dark",
                                            "пользователь" => "bg-info",
                                            _ => "bg-secondary"
                                        };
                                        <tr>
                                            <td class="fw-bold">@(i + 1)</td>
                                            <td>
                                                <a class="text-success fw-medium text-decoration-none"
                                                       asp-area="Admin"
                                                       asp-controller="User"
                                                       asp-action="Detail"
                                                       asp-route-userId="@user.Id">
                                                    @user.UserName
                                                </a>
                                            </td>
                                            <td>@user.FirstName</td>
                                            <td>@user.LastName</td>
                                            <td>@user.Phone</td>
                                            <td>
                                                <span class="badge @roleClass">@user.Role</span>
                                            </td>
                                            <td class="text-end">
                                                <a class="btn btn-sm btn-outline-success"
                                                       asp-area="Admin"
                                                       asp-controller="User"
                                                       asp-action="Detail"
                                                       asp-route-userId="@user.Id">
                                                    <i class="bi bi-eye"></i> Подробнее
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        <div class="text-muted mt-3 text-end">
                            <i class="bi bi-people"></i> Всего пользователей: <strong>@Model.Count</strong>
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted py-5">
                            <i class="bi bi-person-slash" style="font-size: 3rem;"></i>
                            <p class="mt-3 mb-0">Пользователи не найдены</p>
                            <a asp-area="Admin" asp-controller="User" asp-action="Add" class="btn btn-success mt-3">
                                <i class="bi bi-person-plus me-1"></i>Добавить первого пользователя
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>