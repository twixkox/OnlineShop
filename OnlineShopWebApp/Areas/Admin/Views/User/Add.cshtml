@using OnlineShopWebApp.Areas.Client.Models
@model RegistrationUser
@{
    ViewData["Title"] = "Добавление пользователя";
}

<div class="d-flex justify-content-between align-items-center bg-success text-white p-4 mb-4 rounded-3">
    <div>
        <h1 class="h3 mb-0">
            <i class="bi bi-person-plus me-2"></i>@ViewData["Title"]
        </h1>
        <p class="mb-0 small opacity-75">Создание новой учетной записи</p>
    </div>
    <a asp-area="Admin" asp-controller="User" asp-action="Index" class="btn btn-light">
        <i class="bi bi-arrow-left me-1"></i>Назад к списку
    </a>
</div>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-white py-3">
                    <h5 class="card-title mb-0">
                        <i class="bi bi-grid-3x3-gap-fill text-success me-2"></i>
                        Форма регистрации нового пользователя
                    </h5>
                </div>

                <div class="card-body">
                    <form method="post">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-medium" asp-for="FirstName">
                                    <i class="bi bi-person text-success me-1"></i>Имя
                                </label>
                                <input class="form-control" asp-for="FirstName" placeholder="Введите имя" />
                                <span asp-validation-for="FirstName" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-medium" asp-for="LastName">
                                    <i class="bi bi-person text-success me-1"></i>Фамилия
                                </label>
                                <input class="form-control" asp-for="LastName" placeholder="Введите фамилию" />
                                <span asp-validation-for="LastName" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-medium" asp-for="Phone">
                                <i class="bi bi-telephone text-success me-1"></i>Телефон
                            </label>
                            <input class="form-control" asp-for="Phone" placeholder="+7 (999) 999-99-99" />
                            <span asp-validation-for="Phone" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-medium" asp-for="UserName">
                                <i class="bi bi-envelope text-success me-1"></i>Email (логин)
                            </label>
                            <input class="form-control" asp-for="UserName" placeholder="user@example.com" />
                            <span asp-validation-for="UserName" class="text-danger small"></span>
                            <div class="form-text text-muted">
                                Будет использоваться для входа в систему
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-medium" asp-for="Password">
                                    <i class="bi bi-lock text-success me-1"></i>Пароль
                                </label>
                                <div class="input-group">
                                    <input class="form-control" asp-for="Password" type="password" id="passwordField" placeholder="********" />
                                    <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('passwordField', this)">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                </div>
                                <span asp-validation-for="Password" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-medium" asp-for="ReplayPassword">
                                    <i class="bi bi-lock-fill text-success me-1"></i>Подтверждение пароля
                                </label>
                                <div class="input-group">
                                    <input class="form-control" asp-for="ReplayPassword" type="password" id="replayPasswordField" placeholder="********" />
                                    <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('replayPasswordField', this)">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                </div>
                                <span asp-validation-for="ReplayPassword" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-4">
                            <a asp-area="Admin" asp-controller="User" asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-x-circle me-1"></i>Отмена
                            </a>
                            <button type="submit" class="btn btn-success px-5">
                                <i class="bi bi-check-circle me-2"></i>Добавить
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        function togglePassword(fieldId, button) {
            const field = document.getElementById(fieldId);
            const icon = button.querySelector('i');
            if (field.type === 'password') {
                field.type = 'text';
                icon.classList.remove('bi-eye');
                icon.classList.add('bi-eye-slash');
            } else {
                field.type = 'password';
                icon.classList.remove('bi-eye-slash');
                icon.classList.add('bi-eye');
            }
        }
    </script>
}