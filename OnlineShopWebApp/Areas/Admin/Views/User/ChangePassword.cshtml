@model OnlineShopWebApp.Areas.Admin.Models.AdminChangePasswordViewModel
@{
    ViewData["Title"] = "Смена пароля";
}

<!-- Шапка с заголовком и навигацией -->
<div class="d-flex justify-content-between align-items-center bg-success text-white p-4 mb-4 rounded-3">
    <div>
        <h1 class="h3 mb-0">
            <i class="bi bi-key me-2"></i>@ViewData["Title"]
        </h1>
        <p class="mb-0 small opacity-75">Изменение пароля для пользователя @Model.Email</p>
    </div>
    <a asp-area="Admin" asp-controller="User" asp-action="Detail" asp-route-userId="@Model.UserId" class="btn btn-light">
        <i class="bi bi-arrow-left me-1"></i>Назад к профилю
    </a>
</div>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-white py-3">
                    <h5 class="card-title mb-0">
                        <i class="bi bi-grid-3x3-gap-fill text-success me-2"></i>
                        Форма смены пароля
                    </h5>
                </div>

                <div class="card-body">
                    <!-- Информация о пользователе (опционально) -->
                    <div class="alert alert-info bg-light d-flex align-items-center mb-4" role="alert">
                        <i class="bi bi-person-circle fs-4 me-3 text-success"></i>
                        <div>
                            <strong>Пользователь:</strong> @Model.Email
                        </div>
                    </div>

                    <form method="post">
                      

                        <!-- Скрытые поля для идентификации пользователя -->
                        <input type="hidden" asp-for="UserId" />
                        <input type="hidden" asp-for="Email" />

                        <!-- Новый пароль -->
                        <div class="mb-4">
                            <label class="form-label fw-medium" asp-for="Password">
                                <i class="bi bi-lock text-success me-1"></i>Новый пароль
                            </label>
                            <div class="input-group">
                                <input class="form-control" asp-for="Password" type="password" id="passwordField" placeholder="Введите новый пароль" />
                                <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('passwordField', this)">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <!-- Подтверждение пароля -->
                        <div class="mb-4">
                            <label class="form-label fw-medium" asp-for="ConfirmPassword">
                                <i class="bi bi-lock-fill text-success me-1"></i>Подтверждение пароля
                            </label>
                            <div class="input-group">
                                <input class="form-control" asp-for="ConfirmPassword" type="password" id="confirmPasswordField" placeholder="Подтвердите новый пароль" />
                                <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('confirmPasswordField', this)">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>

                        <!-- Кнопки -->
                        <div class="d-flex justify-content-between align-items-center mt-5">
                            <a asp-area="Admin" asp-controller="User" asp-action="Detail" asp-route-userId="@Model.UserId" class="btn btn-outline-secondary">
                                <i class="bi bi-x-circle me-1"></i>Отмена
                            </a>
                            <button type="submit" class="btn btn-success px-5">
                                <i class="bi bi-check-circle me-2"></i>Обновить пароль
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        function togglePassword(fieldId, button) {
            const field = document.getElementById(fieldId);
            const icon = button.querySelector('i');
            if (field.type === 'password') {
                field.type = 'text';
                icon.classList.remove('bi-eye');
                icon.classList.add('bi-eye-slash');
            } else {
                field.type = 'password';
                icon.classList.remove('bi-eye-slash');
                icon.classList.add('bi-eye');
            }
        }
    </script>
}