@model CategoryViewModel
@{
    ViewData["Title"] = "Редактирование товара";
}

<div class="text-center text-uppercase text-success mb-5 mt-5">
    <h2 class="row-title">Редактирование товара</h2>
</div>
<form method="post" enctype="multipart/form-data">
    <div class="row justify-content-center mt-3">
        <div class="col-6 mb-3">
            <input type="hidden" name="Id" value="@Model.Id" />
            
            <p>
                <label class="form-label" asp-for="Name"></label><br />
                <input class="form-control" asp-for="Name" value="@Model.Name" />
                <span asp-validation-for="Name"></span>
            </p>
                        <p>
                <label class="form-label" asp-for="Description"></label><br />
                <textarea class="form-control" asp-for="Description" value="@Model.Description"></textarea>
                <span asp-validation-for="Description"></span>
            </p>
           
        </div>
    </div>
    <div class="text-center m-3">
        <button class="btn btn-outline-success" type="submit">
            Редактировать
        </button>
    </div>
</form>