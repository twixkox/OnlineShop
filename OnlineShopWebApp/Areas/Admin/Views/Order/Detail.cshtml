@using OnlineShopWebApp.Areas.Client.Models
@model OrderViewModel
@{
    ViewData["Title"] = "Детали заказа";
}

<div class="d-flex justify-content-between align-items-center bg-success text-white p-4 mb-4 rounded-3">
    <div>
        <h1 class="h3 mb-0">
            <i class="bi bi-truck me-2"></i>@ViewData["Title"]
        </h1>
        <p class="mb-0 small opacity-75">Просмотр и редактирование информации о заказе</p>
    </div>
    <a asp-area="Admin" asp-controller="Order" asp-action="Index" class="btn btn-light">
        <i class="bi bi-arrow-left me-1"></i>Назад к списку
    </a>
</div>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-12">
            @if (Model != null)
            {
                <div class="card shadow-sm">
                    <div class="card-header bg-white py-3">
                        <h5 class="card-title mb-0">
                            <i class="bi bi-grid-3x3-gap-fill text-success me-2"></i>
                            Информация о заказе
                        </h5>
                    </div>
                    <div class="card-body">
                        <form method="post" asp-area="Admin" asp-controller="Order" asp-action="UpdateOrderStatus">
                            <input type="hidden" name="orderId" value="@Model.Id" />
                            <input type="hidden" asp-for="Id" />

                            <div class="mb-4">
                                <h6 class="fw-bold text-success mb-3">
                                    <i class="bi bi-info-circle me-2"></i>Основные данные
                                </h6>
                                <div class="row">
                                    <div class="col-md-6">
                                        <table class="table table-sm table-borderless">
                                            <tr>
                                                <td class="fw-medium" style="width: 40%;">ID заказа</td>
                                                <td>@Model.Id</td>
                                            </tr>
                                            <tr>
                                                <td class="fw-medium">Общая стоимость</td>
                                                <td class="fw-bold text-success">@Model.TotalCost?.ToString("C")</td>
                                            </tr>
                                            <tr>
                                                <td class="fw-medium">Количество позиций</td>
                                                <td>@Model.Items.Count</td>
                                            </tr>
                                            <tr>
                                                <td class="fw-medium">Количество товаров</td>
                                                <td>@Model.ItemsQuantity</td>
                                            </tr>
                                        </table>
                                    </div>
                                    <div class="col-md-6">
                                        <table class="table table-sm table-borderless">
                                            <tr>
                                                <td class="fw-medium" style="width: 40%;">Дата создания</td>
                                                <td>@Model.CreationDateOrder.ToString("dd.MM.yyyy HH:mm")</td>
                                            </tr>
                                            <tr>
                                                <td class="fw-medium">Статус</td>
                                                <td>
                                                    <select asp-for="Status" class="form-select form-select-sm w-75"
                                                            asp-items="@Html.GetEnumSelectList<OrderStatusViewModel>()">
                                                    </select>
                                                </td>
                                            </tr>
                                        </table>
                                    </div>
                                </div>
                            </div>

                            <div class="mb-4">
                                <h6 class="fw-bold text-success mb-3">
                                    <i class="bi bi-person-circle me-2"></i>Пользователь
                                </h6>
                                <table class="table table-sm table-borderless w-50">
                                    <tr>
                                        <td class="fw-medium" style="width: 30%;">ID пользователя</td>
                                        <td>@Model.UserId</td>
                                    </tr>
                                </table>
                            </div>

                            <div class="mb-4">
                                <h6 class="fw-bold text-success mb-3">
                                    <i class="bi bi-truck me-2"></i>Данные доставки
                                </h6>
                                <div class="row">
                                    <div class="col-md-6">
                                        <table class="table table-sm table-borderless">
                                            <tr>
                                                <td class="fw-medium" style="width: 40%;">Имя</td>
                                                <td>@Model.DeliveryUserInfo?.UserName</td>
                                            </tr>
                                            <tr>
                                                <td class="fw-medium">Телефон</td>
                                                <td>@Model.DeliveryUserInfo?.Phone</td>
                                            </tr>
                                            <tr>
                                                <td class="fw-medium">Адрес</td>
                                                <td>@Model.DeliveryUserInfo?.Adress</td>
                                            </tr>
                                        </table>
                                    </div>
                                    <div class="col-md-6">
                                        <table class="table table-sm table-borderless">
                                            <tr>
                                                <td class="fw-medium" style="width: 40%;">Дата доставки</td>
                                                <td>@(Model.DeliveryUserInfo?.DeliveryDate.ToShortDateString() ?? "")</td>
                                            </tr>
                                            <tr>
                                                <td class="fw-medium">Комментарий</td>
                                                <td>@Model.DeliveryUserInfo?.Comment</td>
                                            </tr>
                                        </table>
                                    </div>
                                </div>
                            </div>

                            <div class="mb-4">
                                <h6 class="fw-bold text-success mb-3">
                                    <i class="bi bi-basket me-2"></i>Состав заказа
                                </h6>
                                <div class="table-responsive">
                                    <table class="table table-hover align-middle">
                                        <thead class="table-light">
                                            <tr>
                                                <th scope="col">#</th>
                                                <th scope="col">Наименование</th>
                                                <th scope="col" class="text-end">Цена</th>
                                                <th scope="col" class="text-center">Количество</th>
                                                <th scope="col" class="text-end">Стоимость</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @for (var i = 0; i < Model.Items.Count; i++)
                                            {
                                                var item = Model.Items[i];
                                                <tr>
                                                    <td class="fw-bold">@(i + 1)</td>
                                                    <td>@item.Product?.Name</td>
                                                    <td class="text-end">@item.Product?.Cost.ToString("C")</td>
                                                    <td class="text-center">@item.Quantity</td>
                                                    <td class="fw-bold text-end">@item.Cost.ToString("C")</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>

                            <div class="d-flex justify-content-between align-items-center mt-5">
                                <a asp-area="Admin" asp-controller="Order" asp-action="Index" class="btn btn-outline-secondary">
                                    <i class="bi bi-x-circle me-1"></i>Отмена
                                </a>
                                <button type="submit" class="btn btn-success px-5">
                                    <i class="bi bi-check-circle me-2"></i>Обновить статус
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            }
            else
            {
                <div class="text-center text-muted py-5">
                    <i class="bi bi-exclamation-triangle" style="font-size: 3rem;"></i>
                    <p class="mt-3 mb-0">Заказ не найден</p>
                    <a asp-area="Admin" asp-controller="Order" asp-action="Index" class="btn btn-success mt-3">
                        <i class="bi bi-arrow-left me-1"></i>Вернуться к списку
                    </a>
                </div>
            }
        </div>
    </div>
</div>