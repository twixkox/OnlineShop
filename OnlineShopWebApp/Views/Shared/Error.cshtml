@model ErrorViewModel
@{
    ViewData["Title"] = "Ошибка сервера";
}

<!-- Шапка с заголовком и навигацией (красная для ошибок) -->
<div class="d-flex justify-content-between align-items-center bg-danger text-white p-4 mb-4 rounded-3">
    <div>
        <h1 class="h3 mb-0">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@ViewData["Title"]
        </h1>
        <p class="mb-0 small opacity-75">Произошла внутренняя ошибка сервера</p>
    </div>
    <a asp-controller="Home" asp-action="Index" class="btn btn-light">
        <i class="bi bi-house-door me-1"></i>На главную
    </a>
</div>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-white py-3">
                    <h5 class="card-title mb-0">
                        <i class="bi bi-grid-3x3-gap-fill text-danger me-2"></i>
                        Что-то пошло не так
                    </h5>
                </div>
                <div class="card-body">
                    <div class="text-center py-4">
                        <i class="bi bi-bug text-danger" style="font-size: 4rem;"></i>
                        <h4 class="mt-3">Мы уже работаем над исправлением</h4>
                        <p class="text-muted">Попробуйте обновить страницу или вернуться позже.</p>

                        <!-- Отображение идентификатора запроса для поддержки (если доступен) -->
                        @if (Model != null && !string.IsNullOrEmpty(Model.RequestId))
                        {
                            <p class="small text-muted">
                                <strong>Request ID:</strong> @Model.RequestId
                            </p>
                        }

                        <!-- Кнопка для возврата на главную -->
                        <a asp-controller="Home" asp-action="Index" class="btn btn-danger mt-3">
                            <i class="bi bi-arrow-left me-1"></i>Вернуться на главную
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>