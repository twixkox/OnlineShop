@using OnlineShopWebApp.Areas.Client.Models
@model OrderViewModel
@{
    ViewData["Title"] = $"Заказ № {Model?.Id}";
}

<div class="d-flex justify-content-between align-items-center bg-success text-white p-4 mb-4 rounded-3">
    <div>
        <h1 class="h3 mb-0">
            <i class="bi bi-truck me-2"></i>Детали заказа
        </h1>
        <p class="mb-0 small opacity-75">Просмотр информации о заказе №@Model?.Id</p>
    </div>
    <a asp-controller="Profile" asp-action="UserOrder" class="btn btn-light">
        <i class="bi bi-arrow-left me-1"></i>Назад к списку
    </a>
</div>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-12">
            @if (Model != null)
            {
                <div class="card shadow-sm">
                    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                        <h5 class="card-title mb-0">
                            <i class="bi bi-grid-3x3-gap-fill text-success me-2"></i>
                            Информация о заказе
                        </h5>
                        <span class="badge @(Model.Status switch
                              {
                                  OrderStatusViewModel.Created => "bg-secondary",
                                  OrderStatusViewModel.Processed => "bg-info",
                                  OrderStatusViewModel.Delivering => "bg-warning",
                                  OrderStatusViewModel.Delivered => "bg-success",
                                  OrderStatusViewModel.Canceled => "bg-danger",
                                  _ => "bg-secondary"
                              }) p-2">
                            @Html.DisplayFor(m => m.Status)
                        </span>
                    </div>

                    <div class="card-body">
                        <div class="row mb-4">
                            <div class="col-md-6">
                                <table class="table table-sm table-borderless">
                                    <tr>
                                        <td class="fw-medium" style="width: 40%;">Номер заказа</td>
                                        <td>@Model.Id</td>
                                    </tr>
                                    <tr>
                                        <td class="fw-medium">Дата создания</td>
                                        <td>@Model.CreationDateOrder.ToString("dd.MM.yyyy HH:mm")</td>
                                    </tr>
                                    <tr>
                                        <td class="fw-medium">Общая сумма</td>
                                        <td class="fw-bold text-success">@Model.TotalCost?.ToString("C")</td>
                                    </tr>
                                </table>
                            </div>
                            <div class="col-md-6">
                                <table class="table table-sm table-borderless">
                                    <tr>
                                        <td class="fw-medium" style="width: 40%;">Получатель</td>
                                        <td>@Model.DeliveryUserInfo?.UserName</td>
                                    </tr>
                                    <tr>
                                        <td class="fw-medium">Телефон</td>
                                        <td>@Model.DeliveryUserInfo?.Phone</td>
                                    </tr>
                                    <tr>
                                        <td class="fw-medium">Адрес доставки</td>
                                        <td>
                                            @Model.DeliveryUserInfo?.Adress
                                            @if (!string.IsNullOrEmpty(Model.DeliveryUserInfo?.Apartment))
                                            {
                                                <span>, кв. @Model.DeliveryUserInfo.Apartment</span>
                                            }
                                        </td>
                                    </tr>
                                    @if (!string.IsNullOrEmpty(Model.DeliveryUserInfo?.Comment))
                                    {
                                        <tr>
                                            <td class="fw-medium">Комментарий</td>
                                            <td>@Model.DeliveryUserInfo.Comment</td>
                                        </tr>
                                    }
                                </table>
                            </div>
                        </div>

                        <h6 class="fw-bold text-success mb-3">
                            <i class="bi bi-basket me-2"></i>Состав заказа
                        </h6>
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th scope="col">#</th>
                                        <th scope="col">Наименование</th>
                                        <th scope="col" class="text-end">Цена</th>
                                        <th scope="col" class="text-center">Количество</th>
                                        <th scope="col" class="text-end">Сумма</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (var i = 0; i < Model.Items.Count; i++)
                                    {
                                        var item = Model.Items[i];
                                        <tr>
                                            <td class="fw-bold">@(i + 1)</td>
                                            <td>@item.Product?.Name</td>
                                            <td class="text-end">@item.Product?.Cost.ToString("C")</td>
                                            <td class="text-center">@item.Quantity</td>
                                            <td class="fw-bold text-end">@item.Cost.ToString("C")</td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot class="table-light">
                                    <tr>
                                        <th colspan="4" class="text-end">Итого:</th>
                                        <th class="text-end text-success">@Model.TotalCost?.ToString("C")</th>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>

                        <div class="d-flex justify-content-end mt-4">
                            <a asp-controller="Profile" asp-action="UserOrder" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left me-1"></i>Вернуться к списку заказов
                            </a>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="text-center text-muted py-5">
                    <i class="bi bi-exclamation-triangle" style="font-size: 3rem;"></i>
                    <p class="mt-3 mb-0">Заказ не найден</p>
                    <a asp-controller="Profile" asp-action="UserOrder" class="btn btn-success mt-3">
                        <i class="bi bi-arrow-left me-1"></i>Вернуться к списку
                    </a>
                </div>
            }
        </div>
    </div>
</div>