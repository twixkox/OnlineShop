@model List<OrderViewModel>
@{
    ViewData["Title"] = "Мои заказы";
}

<!-- Шапка с заголовком и навигацией -->
<div class="d-flex justify-content-between align-items-center bg-success text-white p-4 mb-4 rounded-3">
    <div>
        <h1 class="h3 mb-0">
            <i class="bi bi-truck me-2"></i>@ViewData["Title"]
        </h1>
        <p class="mb-0 small opacity-75">История ваших заказов</p>
    </div>
</div>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-white py-3">
                    <h5 class="card-title mb-0">
                        <i class="bi bi-grid-3x3-gap-fill text-success me-2"></i>
                        Список заказов
                    </h5>
                </div>

                <div class="card-body">
                    @if (Model != null && Model.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th scope="col">#</th>
                                        <th scope="col">Сумма</th>
                                        <th scope="col">Статус</th>
                                        <th scope="col">Дата</th>
                                        <th scope="col">Время</th>
                                        <th scope="col" class="text-end">Детали</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (var i = 0; i < Model.Count; i++)
                                    {
                                        var order = Model[i];
                                        <tr>
                                            <td class="fw-bold">@(i + 1)</td>
                                            <td>@order.TotalCost?.ToString("C")</td>
                                            <td>
                                                @{
                                                    string statusClass = order.Status switch
                                                    {
                                                        OrderStatusViewModel.Created => "bg-secondary",
                                                        OrderStatusViewModel.Processed => "bg-info",
                                                        OrderStatusViewModel.Delivering => "bg-warning",
                                                        OrderStatusViewModel.Delivered => "bg-success",
                                                        OrderStatusViewModel.Canceled => "bg-danger",
                                                        _ => "bg-secondary"
                                                    };
                                                }
                                                <span class="badge @statusClass">
                                                    @Html.DisplayFor(m => order.Status)
                                                </span>
                                            </td>
                                            <td>@order.CreationDateOrder.ToShortDateString()</td>
                                            <td>@order.CreationDateOrder.ToShortTimeString()</td>
                                            <td class="text-end">
                                                <a class="btn btn-sm btn-outline-success"
                                                   asp-controller="Profile"
                                                   asp-action="DetailOrder"
                                                   asp-route-orderId="@order.Id">
                                                    <i class="bi bi-eye"></i> Подробнее
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        <div class="text-muted mt-3 text-end">
                            <i class="bi bi-box-seam"></i> Всего заказов: <strong>@Model.Count</strong>
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted py-5">
                            <i class="bi bi-inbox" style="font-size: 3rem;"></i>
                            <p class="mt-3 mb-0">У вас пока нет заказов</p>
                            <a asp-controller="Catalog" asp-action="AllProducts" class="btn btn-success mt-3">
                                <i class="bi bi-shop me-1"></i>Перейти в каталог
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>