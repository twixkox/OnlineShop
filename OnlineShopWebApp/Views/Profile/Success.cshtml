@{
    ViewData["Title"] = "Успешно";
}

<!-- Шапка с заголовком и кнопкой назад -->
<div class="d-flex justify-content-between align-items-center bg-success text-white p-4 mb-4 rounded-3">
    <div>
        <h1 class="h3 mb-0">
            <i class="bi bi-check-circle-fill me-2"></i>@ViewData["Title"]
        </h1>
        <p class="mb-0 small opacity-75">Операция выполнена успешно</p>
    </div>
    <a asp-controller="Profile" asp-action="ProfileEdit" class="btn btn-light">
        <i class="bi bi-arrow-left me-1"></i>Вернуться в профиль
    </a>
</div>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm text-center">
                <div class="card-body py-5">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-success btn-lg">
                        <i class="bi bi-person-circle me-1"></i>Перейти на главную
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>