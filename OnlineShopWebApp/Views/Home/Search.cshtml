@model List<ProductViewModel>
@{
    ViewData["Title"] = "Результаты поиска";
}

<!-- Шапка с заголовком и навигацией -->
<div class="d-flex justify-content-between align-items-center bg-success text-white p-4 mb-4 rounded-3">
    <div>
        <h1 class="h3 mb-0">
            <i class="bi bi-search me-2"></i>@ViewData["Title"]
        </h1>
        <p class="mb-0 small opacity-75">Товары, соответствующие вашему запросу</p>
    </div>
    <a asp-controller="Catalog" asp-action="AllProducts" class="btn btn-light">
        <i class="bi bi-arrow-left me-1"></i>Назад к каталогу
    </a>
</div>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-white py-3">
                    <h5 class="card-title mb-0">
                        <i class="bi bi-grid-3x3-gap-fill text-success me-2"></i>
                        Найдено товаров: @Model?.Count
                    </h5>
                </div>
                <div class="card-body">
                    @if (Model != null && Model.Any())
                    {
                        @await Html.PartialAsync("ProductsCatalog", Model)
                    }
                    else
                    {
                        <div class="text-center text-muted py-5">
                            <i class="bi bi-inbox" style="font-size: 3rem;"></i>
                            <p class="mt-3 mb-0">По вашему запросу ничего не найдено</p>
                            <a asp-controller="Catalog" asp-action="AllProducts" class="btn btn-success mt-3">
                                <i class="bi bi-arrow-left me-1"></i>Вернуться в каталог
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>