@model ProductViewModel
@{
    ViewData["Title"] = Model?.Name ?? "Товар не найден";
}

<!-- Шапка с заголовком и навигацией -->
<div class="d-flex justify-content-between align-items-center bg-success text-white p-4 mb-4 rounded-3">
    <div>
        <h1 class="h3 mb-0">
            <i class="bi bi-box-seam me-2"></i>@ViewData["Title"]
        </h1>
        <p class="mb-0 small opacity-75">Подробное описание товара</p>
    </div>
    <a asp-controller="Catalog" asp-action="AllProducts" class="btn btn-light">
        <i class="bi bi-arrow-left me-1"></i>Назад в каталог
    </a>
</div>

<div class="container">
    @if (Model != null)
    {
        <div class="row justify-content-center">
            <div class="col-md-10">
                <div class="card shadow-sm">
                    <div class="card-header bg-white py-3">
                        <h5 class="card-title mb-0">
                            <i class="bi bi-grid-3x3-gap-fill text-success me-2"></i>
                            Информация о товаре
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <!-- Левая колонка: изображение -->
                            <div class="col-md-5 mb-4 mb-md-0">
                                <div class="border rounded p-3 bg-light text-center">
                                    <img src="/@Model.PhotoPath" class="img-fluid" alt="@Model.Name" style="max-height: 400px; object-fit: contain;">
                                </div>
                            </div>
                            <!-- Правая колонка: детали -->
                            <div class="col-md-7">
                                <h2 class="text-success mb-3">@Model.Name</h2>
                                <div class="mb-4">
                                    <span class="display-6 fw-bold text-danger">@Model.Cost.ToString("C")</span>
                                </div>
                                <div class="mb-4">
                                    <h6 class="fw-bold text-success">
                                        <i class="bi bi-info-circle me-2"></i>Описание
                                    </h6>
                                    <p class="text-muted">@Model.Description</p>
                                </div>
                                <div class="d-grid gap-2 d-md-flex justify-content-md-start mt-4">
                                    <a class="btn btn-success btn-lg"
                                       asp-controller="Cart"
                                       asp-action="Add"
                                       asp-route-productId="@Model.Id">
                                        <i class="bi bi-cart-plus me-2"></i>Добавить в корзину
                                    </a>
                                    <a class="btn btn-outline-success btn-lg"
                                       asp-controller="Favorite"
                                       asp-action="Add"
                                       asp-route-productId="@Model.Id">
                                        <i class="bi bi-heart me-2"></i>В избранное
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="text-center text-muted py-5">
                    <i class="bi bi-exclamation-triangle" style="font-size: 3rem;"></i>
                    <p class="mt-3 mb-0">Товар не найден</p>
                    <a asp-controller="Catalog" asp-action="AllProducts" class="btn btn-success mt-3">
                        <i class="bi bi-arrow-left me-1"></i>Вернуться в каталог
                    </a>
                </div>
            </div>
        </div>
    }
</div>