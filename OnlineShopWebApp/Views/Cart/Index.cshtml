@using OnlineShopWebApp.Areas.Client.Models
@model CartViewModel
@{
    ViewData["Title"] = "Корзина";
}

<div class="d-flex justify-content-between align-items-center bg-success text-white p-4 mb-4 rounded-3">
    <div>
        <h1 class="h3 mb-0">
            <i class="bi bi-cart me-2"></i>@ViewData["Title"]
        </h1>
        <p class="mb-0 small opacity-75">
            @if (Model != null && Model.Items.Count > 0)
            {
                <span>Товаров: <strong>@Model.Items.Sum(i => i.Quantity)</strong> | Сумма: <strong>@Model.TotalCost.ToString("C")</strong></span>
            }
            else
            {
                <span>Ваша корзина пуста</span>
            }
        </p>
    </div>
    <a asp-controller="Catalog" asp-action="AllProducts" class="btn btn-light">
        <i class="bi bi-arrow-left me-1"></i>Продолжить покупки
    </a>
</div>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-white py-3">
                    <h5 class="card-title mb-0">
                        <i class="bi bi-grid-3x3-gap-fill text-success me-2"></i>
                        Состав корзины
                    </h5>
                </div>

                <div class="card-body">
                    @if (Model != null && Model.Items.Count > 0)
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th scope="col">#</th>
                                        <th scope="col">Наименование</th>
                                        <th scope="col" class="text-end">Цена</th>
                                        <th scope="col" class="text-center">Количество</th>
                                        <th scope="col" class="text-end">Стоимость</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (var i = 0; i < Model.Items.Count; i++)
                                    {
                                        var item = Model.Items[i];
                                        <tr>
                                            <td class="fw-bold">@(i + 1)</td>
                                            <td>@item.Product.Name</td>
                                            <td class="text-end">@item.Product.Cost.ToString("C")</td>
                                            <td>
                                                <div class="d-flex justify-content-center align-items-center gap-2">
                                                    <a class="btn btn-sm btn-outline-success"
                                                       asp-controller="Cart"
                                                       asp-action="Subtract"
                                                       asp-route-productId="@item.Product.Id">
                                                        <i class="bi bi-dash-lg"></i>
                                                    </a>
                                                    <span class="fw-bold mx-2">@item.Quantity</span>
                                                    <a class="btn btn-sm btn-outline-success"
                                                       asp-controller="Cart"
                                                       asp-action="Add"
                                                       asp-route-productId="@item.Product.Id">
                                                        <i class="bi bi-plus-lg"></i>
                                                    </a>
                                                </div>
                                            </td>
                                            <td class="fw-bold text-end">@item.Cost.ToString("C")</td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot class="table-light">
                                    <tr>
                                        <th colspan="4" class="text-end">Общая стоимость:</th>
                                        <th class="text-end text-success">@Model.TotalCost.ToString("C")</th>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-4">
                            <a asp-controller="Cart" asp-action="Clear" asp-route-userId="@Model.UserId"
                               class="btn btn-outline-danger"
                               onclick="return confirm('Очистить корзину?');">
                                <i class="bi bi-trash me-1"></i>Очистить корзину
                            </a>
                            <a asp-controller="Order" asp-action="Index" class="btn btn-success">
                                <i class="bi bi-truck me-1"></i>Оформить заказ
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted py-5">
                            <i class="bi bi-cart-x" style="font-size: 3rem;"></i>
                            <p class="mt-3 mb-0">В корзине нет товаров</p>
                            <a asp-controller="Catalog" asp-action="AllProducts" class="btn btn-success mt-3">
                                <i class="bi bi-shop me-1"></i>Перейти в каталог
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    @if (Model != null && Model.Items.Count > 0)
    {
        <div class="text-center mt-4">
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-success">
                <i class="bi bi-arrow-left me-1"></i>Продолжить покупки
            </a>
        </div>
    }
</div>