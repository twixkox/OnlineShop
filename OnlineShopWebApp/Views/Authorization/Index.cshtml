@using OnlineShopWebApp.Areas.Client.Models
@model AuthorizationUserViewModel
@{
    ViewData["Title"] = "Вход в систему";
}

<!-- Шапка с заголовком -->
<div class="d-flex justify-content-between align-items-center bg-success text-white p-4 mb-4 rounded-3">
    <div>
        <h1 class="h3 mb-0">
            <i class="bi bi-box-arrow-in-right me-2"></i>@ViewData["Title"]
        </h1>
      </div>
    <a asp-controller="Home" asp-action="Index" class="btn btn-light">
        <i class="bi bi-house-door me-1"></i>На главную
    </a>
</div>
<div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 9999;">
<div class="toast show bg-info text-white" role="alertdialog" aria-live="assertive" aria-atomic="false" data-bs-autohide="true" data-bs-delay="3000">
    
    <div class="toast-body">
        @TempData["InfoMessage"]
    </div>
</div>
</div>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3">
                    <h5 class="card-title mb-0">
                        <i class="bi bi-lock text-success me-2"></i>
                        Авторизация
                    </h5>
                </div>

                <div class="card-body p-4">
                    <form method="post" asp-controller="Authorization" asp-action="Authorization">
                        <!-- Вывод ошибок валидации -->
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <!-- Поле для имени пользователя -->
                        <div class="mb-4">
                            <label asp-for="UserName" class="form-label fw-medium">
                                <i class="bi bi-person text-success me-1"></i>Имя пользователя
                            </label>
                            <input asp-for="UserName" class="form-control form-control-lg"
                                   placeholder="Введите имя пользователя" />
                            <span asp-validation-for="UserName" class="text-danger small"></span>
                        </div>

                        <!-- Поле для пароля -->
                        <div class="mb-4">
                            <label asp-for="Password" class="form-label fw-medium">
                                <i class="bi bi-key text-success me-1"></i>Пароль
                            </label>
                            <div class="input-group">
                                <input asp-for="Password" class="form-control form-control-lg"
                                       placeholder="Введите пароль" type="password" id="password" />
                                <button class="btn btn-outline-secondary" type="button"
                                        onclick="togglePasswordVisibility()">
                                    <i class="bi bi-eye" id="togglePasswordIcon"></i>
                                </button>
                            </div>
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <!-- Чекбокс "Запомнить меня" -->
                        <div class="mb-4">
                            <div class="form-check">
                                <input asp-for="RememberMe" class="form-check-input" type="checkbox" />
                                <label asp-for="RememberMe" class="form-check-label">
                                    Запомнить меня на этом устройстве
                                </label>
                            </div>
                        </div>

                        <!-- Кнопки -->
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success btn-lg">
                                <i class="bi bi-box-arrow-in-right me-2"></i>Войти
                            </button>

                            <div class="text-center mt-3">
                                <p class="text-muted mb-2">Нет аккаунта?</p>
                                <a asp-controller="Registration" asp-action="Index"
                                   class="btn btn-outline-success">
                                    <i class="bi bi-person-plus me-2"></i>Зарегистрироваться
                                </a>
                            </div>
                        </div>
                    </form>
                </div>

                <!-- Дополнительная информация -->
                <div class="card-footer bg-white py-3">
                    <div class="small text-center text-muted">
                        <i class="bi bi-shield-check text-success me-1"></i>
                        Ваши данные защищены
                    </div>
                </div>
            </div>

            <!-- Блок с преимуществами -->
            <div class="row g-3 mt-4">
                <div class="col-4">
                    <div class="text-center">
                        <i class="bi bi-truck fs-1 text-success"></i>
                        <p class="small text-muted mt-2">Быстрая доставка</p>
                    </div>
                </div>
                <div class="col-4">
                    <div class="text-center">
                        <i class="bi bi-shield fs-1 text-success"></i>
                        <p class="small text-muted mt-2">Гарантия качества</p>
                    </div>
                </div>
                <div class="col-4">
                    <div class="text-center">
                        <i class="bi bi-arrow-repeat fs-1 text-success"></i>
                        <p class="small text-muted mt-2">Легкий возврат</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Функция для переключения видимости пароля
        function togglePasswordVisibility() {
            const passwordInput = document.getElementById('password');
            const toggleIcon = document.getElementById('togglePasswordIcon');

            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                toggleIcon.classList.remove('bi-eye');
                toggleIcon.classList.add('bi-eye-slash');
            } else {
                passwordInput.type = 'password';
                toggleIcon.classList.remove('bi-eye-slash');
                toggleIcon.classList.add('bi-eye');
            }
        }

        // Добавляем классы для полей при потере фокуса
        document.querySelectorAll('.form-control').forEach(input => {
            input.addEventListener('blur', function() {
                if (this.value) {
                    this.classList.add('is-valid');
                } else {
                    this.classList.remove('is-valid');
                }
            });
        });
        
        
    </script>
  
}