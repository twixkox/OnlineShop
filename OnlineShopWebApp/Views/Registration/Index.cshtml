@using OnlineShopWebApp.Areas.Client.Models
@model RegistrationUser
@{
    ViewData["Title"] = "Регистрация";
}

<!-- Шапка с заголовком и навигацией -->
<div class="d-flex justify-content-between align-items-center bg-success text-white p-4 mb-4 rounded-3">
    <div>
        <h1 class="h3 mb-0">
            <i class="bi bi-person-plus me-2"></i>@ViewData["Title"]
        </h1>
        <p class="mb-0 small opacity-75">Создание новой учетной записи</p>
    </div>
    <a asp-controller="Home" asp-action="Index" class="btn btn-light">
        <i class="bi bi-arrow-left me-1"></i>На главную
    </a>
</div>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm">
                <div class="card-header bg-white py-3">
                    <h5 class="card-title mb-0">
                        <i class="bi bi-grid-3x3-gap-fill text-success me-2"></i>
                        Форма регистрации
                    </h5>
                </div>

                <div class="card-body">

                    <form asp-controller="Registration" asp-action="Registration" method="post">

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <!-- Email (логин) -->
                        <div class="mb-3">
                            <label class="form-label fw-medium" asp-for="UserName">
                                <i class="bi bi-envelope text-success me-1"></i>Email (логин)
                            </label>
                            <input class="form-control" asp-for="UserName" placeholder="user@example.com" />
                            <span asp-validation-for="UserName" class="text-danger small"></span>
                            <div class="form-text text-muted small">Будет использоваться для входа</div>
                        </div>

                        <!-- Пароль и подтверждение -->
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-medium" asp-for="Password">
                                    <i class="bi bi-lock text-success me-1"></i>Пароль
                                </label>
                                <div class="input-group">
                                    <input class="form-control" asp-for="Password" type="password" id="passwordField" placeholder="********" />
                                    <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('passwordField', this)">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                </div>
                                <span asp-validation-for="Password" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-medium" asp-for="ReplayPassword">
                                    <i class="bi bi-lock-fill text-success me-1"></i>Подтверждение
                                </label>
                                <div class="input-group">
                                    <input class="form-control" asp-for="ReplayPassword" type="password" id="confirmPasswordField" placeholder="********" />
                                    <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('confirmPasswordField', this)">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                </div>
                                <span asp-validation-for="ReplayPassword" class="text-danger small"></span>
                            </div>
                        </div>

                        <!-- Имя и фамилия -->
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-medium" asp-for="FirstName">
                                    <i class="bi bi-person text-success me-1"></i>Имя
                                </label>
                                <input class="form-control" asp-for="FirstName" placeholder="Введите имя" />
                                <span asp-validation-for="FirstName" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-medium" asp-for="LastName">
                                    <i class="bi bi-person text-success me-1"></i>Фамилия
                                </label>
                                <input class="form-control" asp-for="LastName" placeholder="Введите фамилию" />
                                <span asp-validation-for="LastName" class="text-danger small"></span>
                            </div>
                        </div>

                        <!-- Телефон -->
                        <div class="mb-3">
                            <label class="form-label fw-medium" asp-for="Phone">
                                <i class="bi bi-telephone text-success me-1"></i>Телефон
                            </label>
                            <input class="form-control phone-input" asp-for="Phone" placeholder="+7 (999) 999-99-99" />
                            <span asp-validation-for="Phone" class="text-danger small"></span>
                        </div>

                        <!-- Кнопки -->
                        <div class="d-flex justify-content-between align-items-center mt-4">
                            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-x-circle me-1"></i>Отмена
                            </a>
                            <!-- Исправлено: убраны лишние атрибуты, теперь работает через форму -->
                            <button type="submit" class="btn btn-success px-4" id="submitBtn">
                                <i class="bi bi-check-circle me-2"></i>Зарегистрироваться
                            </button>
                        </div>
                    </form>
                </div>

                <!-- Ссылка на вход для уже зарегистрированных -->
                <div class="card-footer bg-white py-3 text-center">
                    <p class="mb-0 small">
                        Уже есть аккаунт?
                        <a asp-controller="Authorization" asp-action="Index" class="text-success fw-medium">
                            Войдите <i class="bi bi-box-arrow-in-right ms-1"></i>
                        </a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}