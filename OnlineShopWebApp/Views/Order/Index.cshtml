@using OnlineShopWebApp.Areas.Client.Models
@model OrderViewModel
@{
    ViewData["Title"] = "Оформление заказа";
}
<head>
    <!-- Подключаем API Яндекс.Карт (оставлено без изменений) -->
    <script src="https://api-maps.yandex.ru/2.1/?apikey=3e62edd6-687f-4cb4-990d-4710e34632a1&lang=ru_RU" type="text/javascript"></script>
    <!-- Ваш собственный скрипт для работы с картой -->
    <script src="~/js/index.js"></script>
</head>

<!-- Шапка с заголовком и навигацией -->
<div class="d-flex justify-content-between align-items-center bg-success text-white p-4 mb-4 rounded-3">
    <div>
        <h1 class="h3 mb-0">
            <i class="bi bi-truck me-2"></i>@ViewData["Title"]
        </h1>
        <p class="mb-0 small opacity-75">Заполните данные для доставки</p>
    </div>
    <a asp-controller="Cart" asp-action="Index" class="btn btn-light">
        <i class="bi bi-arrow-left me-1"></i>Назад в корзину
    </a>
</div>

<div class="container">
    @if (Model != null && Model.Items.Count > 0)
    {
        <div class="row justify-content-center">
            <div class="col-12">
                <div class="card shadow-sm">
                    <div class="card-header bg-white py-3">
                        <h5 class="card-title mb-0">
                            <i class="bi bi-grid-3x3-gap-fill text-success me-2"></i>
                            Информация о заказе и покупателе
                        </h5>
                    </div>
                    <div class="card-body">
                        <form method="post">
                            <div class="row">
                                <!-- Левая колонка: данные покупателя + карта -->
                                <div class="col-md-6">
                                    <h6 class="fw-bold text-success mb-3">
                                        <i class="bi bi-person-circle me-2"></i>Данные получателя
                                    </h6>
                                    <div class="mb-3">
                                        <label class="form-label fw-medium" asp-for="DeliveryUserInfo.UserName"></label>
                                        <input class="form-control" asp-for="DeliveryUserInfo.UserName" placeholder="Иванов Иван" />
                                        <span asp-validation-for="DeliveryUserInfo.UserName" class="text-danger small"></span>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label fw-medium" asp-for="DeliveryUserInfo.Phone"></label>
                                        <input class="form-control" asp-for="DeliveryUserInfo.Phone" id="phoneInput" placeholder="+7 (999) 999-99-99" />
                                        <span asp-validation-for="DeliveryUserInfo.Phone" class="text-danger small"></span>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label fw-medium" asp-for="DeliveryUserInfo.Adress"></label>
                                        <input class="form-control" asp-for="DeliveryUserInfo.Adress" id="deliveryAddress" placeholder="ул. Садовая, д. 1" />
                                        <span asp-validation-for="DeliveryUserInfo.Adress" class="text-danger small"></span>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label fw-medium" asp-for="DeliveryUserInfo.Apartment"></label>
                                        <input class="form-control" asp-for="DeliveryUserInfo.Apartment" placeholder="кв./офис" />
                                        <span asp-validation-for="DeliveryUserInfo.Apartment" class="text-danger small"></span>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label fw-medium" asp-for="DeliveryUserInfo.DeliveryDate"></label>
                                        <input class="form-control" asp-for="DeliveryUserInfo.DeliveryDate" type="date" />
                                        <span asp-validation-for="DeliveryUserInfo.DeliveryDate" class="text-danger small"></span>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label fw-medium" asp-for="DeliveryUserInfo.Comment"></label>
                                        <textarea class="form-control" asp-for="DeliveryUserInfo.Comment" rows="3" placeholder="Комментарий к заказу"></textarea>
                                        <span asp-validation-for="DeliveryUserInfo.Comment" class="text-danger small"></span>
                                    </div>

                                    <!-- Карта (без изменений, управляется вашим скриптом index.js) -->
                                    <h6 class="fw-bold text-success mt-4 mb-3">
                                        <i class="bi bi-geo-alt-fill me-2"></i>Выберите точку на карте
                                    </h6>
                                    <div id="map" style="width: 100%; height: 300px; border-radius: 8px;"></div>
                                </div>

                                <!-- Правая колонка: состав заказа -->
                                <div class="col-md-6">
                                    <h6 class="fw-bold text-success mb-3">
                                        <i class="bi bi-basket me-2"></i>Состав заказа
                                    </h6>
                                    <div class="table-responsive">
                                        <table class="table table-hover align-middle">
                                            <thead class="table-light">
                                                <tr>
                                                    <th scope="col">#</th>
                                                    <th scope="col">Наименование</th>
                                                    <th scope="col" class="text-end">Цена</th>
                                                    <th scope="col" class="text-center">Кол-во</th>
                                                    <th scope="col" class="text-end">Сумма</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @for (var i = 0; i < Model.Items.Count; i++)
                                                {
                                                    var item = Model.Items[i];
                                                    <tr>
                                                        <td class="fw-bold">@(i + 1)</td>
                                                        <td>@item.Product.Name</td>
                                                        <td class="text-end">@item.Product.Cost.ToString("C")</td>
                                                        <td class="text-center">@item.Quantity</td>
                                                        <td class="fw-bold text-end">@item.Cost.ToString("C")</td>
                                                    </tr>
                                                }
                                            </tbody>
                                            <tfoot class="table-light">
                                                <tr>
                                                    <th colspan="4" class="text-end">Общая стоимость:</th>
                                                    <th class="text-end text-success">@Model.TotalCost?.ToString("C")</th>
                                                </tr>
                                            </tfoot>
                                        </table>
                                    </div>
                                </div>
                            </div>

                            <!-- Кнопки -->
                            <div class="d-flex justify-content-between align-items-center mt-4">
                                <a asp-controller="Cart" asp-action="Index" class="btn btn-outline-secondary">
                                    <i class="bi bi-x-circle me-1"></i>Вернуться в корзину
                                </a>
                                <button class="btn btn-outline-success" type="submit"
                                        asp-controller="Order"
                                        asp-action="Buy">
                                    Оплатить заказ
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center text-muted py-5">
            <i class="bi bi-inbox" style="font-size: 3rem;"></i>
            <p class="mt-3 mb-0">Нет заказа для оформления</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-success mt-3">
                <i class="bi bi-shop me-1"></i>Перейти в каталог
            </a>
        </div>
    }
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <!-- Скрипт форматирования телефона (оставлен без изменений) -->
    <script>
        function formatPhone(input) {
            let numbers = input.value.replace(/\D/g, '');
            if (numbers.startsWith('7') || numbers.startsWith('8')) {
                numbers = numbers.substring(1);
            }
            numbers = numbers.slice(0, 11);
            let formatted = '';
            if (numbers.length > 0) {
                formatted = '+7';
                if (numbers.length > 0) {
                    formatted += ' (' + numbers.substring(0, 3);
                }
                if (numbers.length >= 4) {
                    formatted += ') ' + numbers.substring(3, 6);
                }
                if (numbers.length >= 7) {
                    formatted += '-' + numbers.substring(6, 8);
                }
                if (numbers.length >= 9) {
                    formatted += '-' + numbers.substring(8, 10);
                }
            }
            input.value = formatted;
        }

        document.addEventListener('DOMContentLoaded', function() {
            const phoneInput = document.getElementById('phoneInput');
            if (phoneInput) {
                formatPhone(phoneInput);
                phoneInput.addEventListener('input', function() {
                    formatPhone(this);
                });
            }
        });
    </script>
}