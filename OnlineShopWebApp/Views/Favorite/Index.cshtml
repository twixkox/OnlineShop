@using OnlineShopWebApp.Areas.Client.Models
@model FavoriteViewModel
@{
    ViewData["Title"] = "Избранное";
}

<!-- Шапка с заголовком и навигацией -->
<div class="d-flex justify-content-between align-items-center bg-success text-white p-4 mb-4 rounded-3">
    <div>
        <h1 class="h3 mb-0">
            <i class="bi bi-heart-fill me-2"></i>@ViewData["Title"]
        </h1>
        <p class="mb-0 small opacity-75">Список избранных товаров</p>
    </div>
    <a asp-controller="Home" asp-action="Index" class="btn btn-light">
        <i class="bi bi-arrow-left me-1"></i>Назад к каталогу
    </a>
</div>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-body">
                    @if (Model != null && Model.Items?.Count > 0)
                    {
                        <div class="row g-4">
                            @foreach (var product in Model.Items)
                            {
                                <div class="col-md-3 col-6">
                                    <div class="card h-100 shadow-sm">
                                        <img src="@product.PhotoPath" class="card-img-top" alt="@product.Name"
                                             style="height: 250px; object-fit: cover;">
                                        <div class="card-body d-flex flex-column">
                                            <a asp-controller="Product" asp-action="Index" asp-route-id="@product.Id"
                                               class="text-success text-decoration-none">
                                                <h5 class="card-title">@product.Name</h5>
                                            </a>
                                            <p class="card-text text-danger fw-bold fs-5">@product.Cost.ToString("C")</p>
                                            <p class="card-text small text-muted flex-grow-1">@product.Description</p>
                                            <div class="d-grid gap-2 mt-2">
                                                <a asp-controller="Cart" asp-action="Add" asp-route-productId="@product.Id"
                                                   class="btn btn-success">
                                                    <i class="bi bi-cart-plus me-1"></i>В корзину
                                                </a>
                                                <a asp-controller="Favorite" asp-action="Delete"
                                                   asp-route-productId="@product.Id"
                                                   asp-route-userId="@Model.UserId"
                                                   class="btn btn-outline-danger">
                                                    <i class="bi bi-heartbreak me-1"></i>Убрать
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted py-5">
                            <i class="bi bi-heart" style="font-size: 3rem;"></i>
                            <p class="mt-3 mb-0">В избранном пока нет товаров</p>
                            <a asp-controller="Home" asp-action="Index" class="btn btn-success mt-3">
                                <i class="bi bi-shop me-1"></i>Перейти в каталог
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    @if (Model != null && Model.Items?.Count > 0)
    {
        <div class="text-center mt-4">
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-success">
                <i class="bi bi-arrow-left me-1"></i>Продолжить покупки
            </a>
        </div>
    }
</div>